AUTH_ENABLED=0
AUTH_TOKEN=
RL_ENABLED=0
RL_MAX=60
RL_WINDOW_MS=60000
PROCESS_TIMEOUT_MS=3000
MAX_HTML_LENGTH=5000000
MAX_FETCH_LENGTH=3000000
HTTP_USER_AGENT=html-to-md/0.1 (+https://example.local)
MAX_REDIRECTS=5
REDIS_URL=redis://localhost:6379/0

# Database Configuration Examples:
# PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://md_user:md_password@localhost:5432/md_db
# MySQL:
# DATABASE_URL=mysql+aiomysql://md_user:md_password@localhost:3306/md_db
# SQLite:
DATABASE_URL=sqlite+aiosqlite:///./md.db
